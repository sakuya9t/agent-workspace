# Rust
/target
**/*.rs.bk
Cargo.lock.orig

# Node / client
node_modules/
client/dist/
client/.vite/
*.tsbuildinfo

# Local runtime data
.asm/
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# TLS material (ASM_TLS_CERT/KEY, ASM_RELAY_TLS_CERT/KEY). Certificates are
# host-specific and the key is a secret — never commit either.
*.pem
*.key
